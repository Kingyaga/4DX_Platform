{
  "name": "4dx-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:backend": "tsx --test server/**/*.test.ts",
    "notify:wigs-at-risk": "ts-node --compiler-options {\"module\":\"CommonJS\"} -r tsconfig-paths/register scripts/check-wigs-at-risk.ts",
    "cron:generate-sessions": "ts-node --compiler-options {\"module\":\"CommonJS\"} -r tsconfig-paths/register scripts/generate-weekly-sessions.ts",
    "cron:mark-overdue": "ts-node --compiler-options {\"module\":\"CommonJS\"} -r tsconfig-paths/register scripts/mark-overdue-sessions.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@trpc/client": "^11.16.0",
    "@trpc/next": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "next": "16.2.4",
    "next-auth": "4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "superjson": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/engines": "^7.8.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
