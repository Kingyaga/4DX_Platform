generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ORGANIZATION ───────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())

  memberships  OrgMembership[]
  teams        Team[]
  invites      Invite[]
  apiKeys      ApiKey[]
  inviteTokens InviteToken[]
}

// ─── USER ───────────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String
  passwordHash        String?
  createdAt           DateTime @default(now())
  defaultTeamId       String?
  mustChangePassword  Boolean  @default(false)

  orgMemberships      OrgMembership[]
  teamMemberships     TeamMembership[]
  activityLogs        ActivityLog[]
  weeklySessions      WeeklySession[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  leadMeasures        LeadMeasureOwner[]
  createdInvites      InviteToken[]
  invites             Invite[]
  passwordResetTokens PasswordResetToken[]
}

// ─── ORG MEMBERSHIP ─────────────────────────────────────────────────────────

model OrgMembership {
  id   String  @id @default(cuid())
  role OrgRole

  userId String
  user   User   @relation(fields: [userId], references: [id])

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
  @@index([orgId])
}

enum OrgRole {
  ADMIN
  MEMBER
}

model Invite {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  invitedByUserId String
  invitedBy       User   @relation(fields: [invitedByUserId], references: [id])

  @@index([orgId])
  @@index([teamId])
  @@index([invitedByUserId])
  @@index([expiresAt])
}

// ─── TEAM ───────────────────────────────────────────────────────────────────

model Team {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  leadUserId String
  members    TeamMembership[]
  wigs       WIG[]
  invites    Invite[]
  inviteTokens InviteToken[]

  @@index([orgId])
  @@index([leadUserId])
}

model TeamMembership {
  id       String   @id @default(cuid())
  role     TeamRole
  joinedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
  @@index([teamId])
}

enum TeamRole {
  LEAD
  MEMBER
  OBSERVER
}

// ─── WIG ────────────────────────────────────────────────────────────────────

model WIG {
  id           String    @id @default(cuid())
  title        String
  description  String?
  trackingType TrackingType @default(NUMERIC)
  fromValue    Float?
  toValue      Float?
  currentValue Float?
  unit         String?
  deadline     DateTime
  status       WIGStatus @default(DRAFT)
  createdAt    DateTime  @default(now())
  closedAt     DateTime?

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  createdByUserId String

  leadMeasures   LeadMeasure[]
  weeklySessions WeeklySession[]

  @@index([teamId])
  @@index([createdByUserId])
  @@index([status])
}

enum WIGStatus {
  DRAFT
  ACTIVE
  ACHIEVED
  MISSED
  ABANDONED
}

// ─── LEAD MEASURE ───────────────────────────────────────────────────────────

model LeadMeasure {
  id          String    @id @default(cuid())
  name        String
  description String?
  trackingType TrackingType @default(NUMERIC)
  cadence     Cadence
  targetValue Float?
  unit        String?
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?

  wigId String
  wig   WIG    @relation(fields: [wigId], references: [id])

  owners       LeadMeasureOwner[]
  activityLogs ActivityLog[]
  commitments  Commitment[]

  @@index([wigId])
}

enum Cadence {
  WEEKLY
  BIWEEKLY
}

model LeadMeasureOwner {
  id String @id @default(cuid())

  leadMeasureId String
  leadMeasure   LeadMeasure @relation(fields: [leadMeasureId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([leadMeasureId, userId])
  @@index([userId])
}

// ─── ACTIVITY LOG ───────────────────────────────────────────────────────────

model ActivityLog {
  id            String            @id @default(cuid())
  value         Float?
  progressStatus ActivityProgressStatus?
  payloadJson   Json?
  loggedForDate DateTime
  note          String?
  status        ActivityLogStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  editedAt      DateTime?

  leadMeasureId String
  leadMeasure   LeadMeasure @relation(fields: [leadMeasureId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([leadMeasureId])
  @@index([userId])
  @@index([loggedForDate])
  @@index([payloadJson], type: Gin)
}

enum ActivityLogStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TrackingType {
  NUMERIC
  MILESTONE
}

enum ActivityProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
}

// ─── WEEKLY SESSION ──────────────────────────────────────────────────────────

model WeeklySession {
  id            String        @id @default(cuid())
  weekStarting  DateTime
  status        SessionStatus @default(PENDING)
  accountDoneAt DateTime?
  reviewDoneAt  DateTime?
  commitDoneAt  DateTime?
  snapshotJson  Json?
  createdAt     DateTime      @default(now())

  wigId String
  wig   WIG    @relation(fields: [wigId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  commitments Commitment[]

  @@index([wigId])
  @@index([userId])
  @@index([wigId, userId, weekStarting])
  @@index([snapshotJson], type: Gin)
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  OVERDUE
}

// ─── COMMITMENT ──────────────────────────────────────────────────────────────

model Commitment {
  id            String           @id @default(cuid())
  text          String
  status        CommitmentStatus @default(PENDING)
  notDoneReason NotDoneReason?
  reflection    String?
  resolvedAt    DateTime?

  weeklySessionId String
  weeklySession   WeeklySession @relation(fields: [weeklySessionId], references: [id])

  linkedLeadMeasureId String?
  linkedLeadMeasure   LeadMeasure? @relation(fields: [linkedLeadMeasureId], references: [id])

  @@index([weeklySessionId])
  @@index([linkedLeadMeasureId])
}

enum CommitmentStatus {
  PENDING
  DONE
  PARTIAL
  NOT_DONE
}

enum NotDoneReason {
  WHIRLWIND
  MISJUDGED
  BLOCKED
  OTHER
}

// ─── NOTIFICATION ────────────────────────────────────────────────────────────

model Notification {
  id          String    @id @default(cuid())
  type        String
  payloadJson Json
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([readAt])
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  actorUserId String
  actor       User   @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType, entityId])
}

// ─── API KEY ─────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique
  name       String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model InviteToken {
  id              String    @id @default(cuid())
  token           String    @unique
  email           String? // optional — pre-fill signup form
  orgId           String
  teamId          String? // optional — auto add to team on signup
  role            OrgRole   @default(MEMBER)
  usedAt          DateTime?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  createdByUserId String

  org       Organization @relation(fields: [orgId], references: [id])
  team      Team?        @relation(fields: [teamId], references: [id])
  createdBy User         @relation(fields: [createdByUserId], references: [id])

  @@index([orgId])
  @@index([teamId])
  @@index([createdByUserId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
