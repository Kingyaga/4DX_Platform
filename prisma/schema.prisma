generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  timezone     String          @default("UTC")
  createdAt    DateTime        @default(now())
  apiKeys      ApiKey[]
  invites      Invite[]
  inviteTokens InviteToken[]
  auditLogs    AuditLog[]
  memberships  OrgMembership[]
  teams        Team[]
}

model User {
  id                  String                 @id @default(cuid())
  email               String                 @unique
  name                String
  passwordHash        String?
  createdAt           DateTime               @default(now())
  defaultTeamId       String?
  mustChangePassword  Boolean                @default(false)
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  invites             Invite[]
  createdInvites      InviteToken[]
  leadMeasures        LeadMeasureOwner[]
  notifications       Notification[]
  orgMemberships      OrgMembership[]
  passwordResetTokens PasswordResetToken[]
  sessionBlockers     SessionBlocker[]
  sessionTimeline     SessionTimelineEvent[]
  teamMemberships     TeamMembership[]
  facilitatedSessions WeeklySession[]        @relation("WeeklySessionFacilitator")
  weeklySessions      WeeklySession[]        @relation("WeeklySessionUser")
}

model OrgMembership {
  id     String       @id @default(cuid())
  role   OrgRole
  userId String
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id])
  user   User         @relation(fields: [userId], references: [id])

  @@unique([userId, orgId])
  @@index([orgId])
}

model Invite {
  id              String       @id @default(cuid())
  token           String       @unique
  email           String?
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  usedAt          DateTime?
  orgId           String
  teamId          String?
  invitedByUserId String
  invitedBy       User         @relation(fields: [invitedByUserId], references: [id])
  org             Organization @relation(fields: [orgId], references: [id])
  team            Team?        @relation(fields: [teamId], references: [id])

  @@index([orgId])
  @@index([teamId])
  @@index([invitedByUserId])
  @@index([expiresAt])
}

model Team {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  createdAt      DateTime         @default(now())
  archivedAt     DateTime?
  orgId          String
  leadUserId     String
  invites        Invite[]
  inviteTokens   InviteToken[]
  org            Organization     @relation(fields: [orgId], references: [id])
  members        TeamMembership[]
  wigs           WIG[]
  weeklySessions WeeklySession[]

  @@index([orgId])
  @@index([leadUserId])
}

model TeamMembership {
  id       String   @id @default(cuid())
  role     TeamRole
  joinedAt DateTime @default(now())
  userId   String
  teamId   String
  team     Team     @relation(fields: [teamId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, teamId])
  @@index([teamId])
}

model WIG {
  id              String          @id @default(cuid())
  title           String
  description     String?
  fromValue       Float?
  toValue         Float?
  currentValue    Float?          @default(0)
  unit            String?
  deadline        DateTime
  status          WIGStatus       @default(DRAFT)
  createdAt       DateTime        @default(now())
  closedAt        DateTime?
  teamId          String
  createdByUserId String
  trackingType    TrackingType    @default(NUMERIC)
  leadMeasures    LeadMeasure[]
  team            Team            @relation(fields: [teamId], references: [id])
  weeklySessions  WeeklySession[]

  @@index([teamId])
  @@index([createdByUserId])
  @@index([status])
}

model LeadMeasure {
  id           String             @id @default(cuid())
  name         String
  description  String?
  cadence      Cadence
  targetValue  Float?
  unit         String?
  createdAt    DateTime           @default(now())
  archivedAt   DateTime?
  wigId        String
  trackingType TrackingType       @default(NUMERIC)
  activityLogs ActivityLog[]
  commitments  Commitment[]
  wig          WIG                @relation(fields: [wigId], references: [id])
  owners       LeadMeasureOwner[]

  @@index([wigId])
}

model LeadMeasureOwner {
  id            String      @id @default(cuid())
  leadMeasureId String
  userId        String
  leadMeasure   LeadMeasure @relation(fields: [leadMeasureId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([leadMeasureId, userId])
  @@index([userId])
}

model ActivityLog {
  id             String                  @id @default(cuid())
  value          Float?
  loggedForDate  DateTime
  note           String?
  createdAt      DateTime                @default(now())
  editedAt       DateTime?
  leadMeasureId  String
  userId         String
  status         ActivityLogStatus       @default(PENDING)
  progressStatus ActivityProgressStatus?
  payloadJson    Json?
  trackingType   TrackingType            @default(NUMERIC)
  valueJson      Json?
  leadMeasure    LeadMeasure             @relation(fields: [leadMeasureId], references: [id])
  user           User                    @relation(fields: [userId], references: [id])

  @@index([leadMeasureId])
  @@index([userId])
  @@index([loggedForDate])
  @@index([payloadJson], type: Gin)
}

model WeeklySession {
  id                String                 @id @default(cuid())
  weekStarting      DateTime
  status            SessionStatus          @default(PENDING)
  accountDoneAt     DateTime?
  reviewDoneAt      DateTime?
  commitDoneAt      DateTime?
  createdAt         DateTime               @default(now())
  wigId             String?
  userId            String?
  snapshotJson      Json?
  title             String?
  weekEnding        DateTime?
  notes             String?
  confidenceScore   Int?
  startedAt         DateTime?
  completedAt       DateTime?
  teamId            String?
  facilitatorUserId String?
  commitments       Commitment[]
  blockers          SessionBlocker[]
  timeline          SessionTimelineEvent[]
  facilitator       User?                  @relation("WeeklySessionFacilitator", fields: [facilitatorUserId], references: [id])
  team              Team?                  @relation(fields: [teamId], references: [id])
  user              User?                  @relation("WeeklySessionUser", fields: [userId], references: [id], onDelete: Restrict)
  wig               WIG?                   @relation(fields: [wigId], references: [id], onDelete: Restrict)

  @@index([wigId])
  @@index([userId])
  @@index([teamId])
  @@index([facilitatorUserId])
  @@index([wigId, userId, weekStarting])
  @@index([teamId, weekStarting])
  @@index([snapshotJson], type: Gin)
}

model Commitment {
  id                  String           @id @default(cuid())
  text                String
  status              CommitmentStatus @default(PENDING)
  notDoneReason       NotDoneReason?
  reflection          String?
  resolvedAt          DateTime?
  weeklySessionId     String
  linkedLeadMeasureId String?
  createdAt           DateTime         @default(now())
  linkedLeadMeasure   LeadMeasure?     @relation(fields: [linkedLeadMeasureId], references: [id])
  weeklySession       WeeklySession    @relation(fields: [weeklySessionId], references: [id])

  @@index([weeklySessionId])
  @@index([linkedLeadMeasureId])
}

model SessionBlocker {
  id              String        @id @default(cuid())
  title           String
  details         String?
  status          BlockerStatus @default(OPEN)
  createdAt       DateTime      @default(now())
  resolvedAt      DateTime?
  weeklySessionId String
  createdByUserId String
  createdBy       User          @relation(fields: [createdByUserId], references: [id])
  weeklySession   WeeklySession @relation(fields: [weeklySessionId], references: [id], onDelete: Cascade)

  @@index([weeklySessionId])
  @@index([createdByUserId])
}

model SessionTimelineEvent {
  id              String        @id @default(cuid())
  type            String
  payloadJson     Json?
  createdAt       DateTime      @default(now())
  weeklySessionId String
  actorUserId     String
  actor           User          @relation(fields: [actorUserId], references: [id])
  weeklySession   WeeklySession @relation(fields: [weeklySessionId], references: [id], onDelete: Cascade)

  @@index([weeklySessionId])
  @@index([actorUserId])
}

model Notification {
  id          String    @id @default(cuid())
  type        String
  payloadJson Json
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([readAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())
  actorUserId String
  orgId       String
  actor       User     @relation(fields: [actorUserId], references: [id])
  org         Organization @relation(fields: [orgId], references: [id])

  @@index([actorUserId])
  @@index([orgId])
  @@index([entityType, entityId])
}

model ApiKey {
  id         String       @id @default(cuid())
  key        String       @unique
  name       String?
  createdAt  DateTime     @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model InviteToken {
  id              String       @id @default(cuid())
  token           String       @unique
  email           String?
  orgId           String
  teamId          String?
  role            OrgRole      @default(MEMBER)
  usedAt          DateTime?
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  createdByUserId String
  createdBy       User         @relation(fields: [createdByUserId], references: [id])
  org             Organization @relation(fields: [orgId], references: [id])
  team            Team?        @relation(fields: [teamId], references: [id])

  @@index([orgId])
  @@index([teamId])
  @@index([createdByUserId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum OrgRole {
  ADMIN
  MEMBER
}

enum TeamRole {
  LEAD
  MEMBER
  OBSERVER
}

enum WIGStatus {
  DRAFT
  ACTIVE
  ACHIEVED
  MISSED
  ABANDONED
}

enum Cadence {
  WEEKLY
  BIWEEKLY
}

enum ActivityLogStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TrackingType {
  NUMERIC
  MILESTONE
  BOOLEAN
  TIME
  TEXT
  PERCENTAGE
  DURATION
  CHECKLIST
  COMPLETION
  HYBRID
  CUSTOM
}

enum ActivityProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  OVERDUE
}

enum CommitmentStatus {
  PENDING
  DONE
  PARTIAL
  NOT_DONE
}

enum NotDoneReason {
  WHIRLWIND
  MISJUDGED
  BLOCKED
  OTHER
}

enum BlockerStatus {
  OPEN
  RESOLVED
}
